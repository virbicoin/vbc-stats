# vbc-stats — SSG 構成の Nginx リバースプロキシ例
#
# フロント（Vite の出力 dist/）を Nginx が静的配信し、WebSocket(Primus) と
# geoip API のみ Node プロセス（server.ts, 既定 :5000）へリバースプロキシする。
# Cloudflare は本 Nginx の前段でプロキシするだけ（オリジンは同一ドメイン stats.virbicoin.com）。
#
# 使い方:
#   1) VPS で `npm ci && npm run build` を実行し dist/ を生成
#   2) `npm run start`（NODE_ENV=production）で server.ts を :5000 で常駐（pm2/systemd 等）
#   3) このファイルを /etc/nginx/sites-available/ 等に置き、root を実際の dist/ パスに直す
#   4) `nginx -t && systemctl reload nginx`

# WebSocket アップグレード用（http ブロックに1つあれば良い）
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name stats.virbicoin.com;

    # --- 静的フロント（Vite 出力 dist/）---
    root /home/aoi/stats/dist;   # ← VPS 上の dist/ 絶対パスに合わせる
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;   # SPA フォールバック（未知パスは index.html）
    }

    # 静的アセットは長期キャッシュ（Vite はファイル名にハッシュを付与）
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # --- WebSocket (Primus): /primus /external /api → Node バックエンド ---
    location ~ ^/(primus|external|api)(/|$) {
        proxy_pass http://127.0.0.1:5000;   # server.ts の PORT（.env の PORT に合わせる）
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;           # WebSocket を長時間維持
    }

    # --- geoip API（通常の HTTP）---
    location /geoip {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
